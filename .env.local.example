# Supabase (publishable + secret keys from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Perplexity (contact enrichment)
PERPLEXITY_API_KEY=your-perplexity-api-key

# Stripe (test keys — also set in Vercel)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
NEXT_PUBLIC_APP_URL=https://abccard.io

# Google OAuth (must match Supabase Auth → Google provider credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (transactional email — also set in Vercel)
RESEND_API_KEY=re_...
